def link_tbb(env):
    import sys

    if not env.get("is_msvc", False) and not env.get("use_mingw", False) and sys.platform != "darwin":
        env.ParseConfig("pkg-config tbb --cflags --libs")


if env.get("is_msvc", False):
    env.AppendUnique(CXXFLAGS=["/external:W0"])

build_openvic_dataloader(env)
build_lexy_vdf(env)
build_ordered_map(env)
build_colony(env)
build_function2(env)
build_std_function(env)
build_memory(env)
build_spdlog(env)
build_xoshiro(env)
build_type_safe(env)
build_int128(env)
link_tbb(env)

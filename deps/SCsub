def build_memory(env):
    import os

    import methods

    env.Append(
        CPPDEFINES=[
            ("FOONATHAN_MEMORY", 1),
            ("FOONATHAN_MEMORY_VERSION_MAJOR", 0),
            ("FOONATHAN_MEMORY_VERSION_MINOR", 7),
            ("FOONATHAN_MEMORY_VERSION_PATCH", 4),
        ]
    )

    config_data = {
        "FOONATHAN_MEMORY_CHECK_ALLOCATION_SIZE": 1,
        "FOONATHAN_MEMORY_IMPL_DEFAULT_ALLOCATOR": "heap_allocator",
        "FOONATHAN_MEMORY_DEBUG_ASSERT": 0,
        "FOONATHAN_MEMORY_DEBUG_FILL": 0,
        "FOONATHAN_MEMORY_DEBUG_FENCE": 0,
        "FOONATHAN_MEMORY_DEBUG_LEAK_CHECK": 0,
        "FOONATHAN_MEMORY_DEBUG_POINTER_CHECK": 0,
        "FOONATHAN_MEMORY_DEBUG_DOUBLE_DEALLOC_CHECK": 0,
        "FOONATHAN_MEMORY_EXTERN_TEMPLATE": 1,
        "FOONATHAN_MEMORY_TEMPORARY_STACK_MODE": 2,
    }

    memory_env, library = env.BuildDependencyLibrary(
        target="libmemory", src_dir="memory/src", include_dir="memory/include"
    )

    memory_env.Append(
        BUILDERS={
            "GenerateMemoryConfig": memory_env.Builder(
                action=methods.generate_memory_config_header, emitter=methods.memory_config_header_emitter
            ),
            "GenerateMemoryContainerNodeSizes": memory_env.Builder(
                action=methods.generate_memory_container_size_header, emitter=methods.memory_config_header_emitter
            ),
        }
    )

    inner_include_dir = "memory/include/foonathan/memory"

    memory_env.Append(CPPPATH=[env.Dir(inner_include_dir)])
    config = memory_env.GenerateMemoryConfig(
        os.path.join(inner_include_dir, "config_impl.hpp"),
        env.Value(config_data),
    )
    node_size_impl = memory_env.GenerateMemoryContainerNodeSizes(
        os.path.join(inner_include_dir, "detail/container_node_sizes_impl.hpp"),
        "SCsub",
    )
    Depends(library, [config, node_size_impl])

    if memory_env.get("is_msvc", False):
        if memory_env.get("use_clang_cl"):
            memory_env.Append(
                CXXFLAGS=["-pedantic-errors", "-Werror", "-Wall", "-Wextra", "-Wconversion", "-Wsign-conversion"]
            )
        else:
            memory_env.Append(CXXFLAGS=["/WX", "/W3", "/D", "_CRT_SECURE_NO_WARNINGS"])
    else:
        memory_env.Append(
            CXXFLAGS=["-pedantic-errors", "-Werror", "-Wall", "-Wextra", "-Wconversion", "-Wsign-conversion"]
        )


def build_spdlog(env):
    import os

    spdlog_level = "SPDLOG_LEVEL_INFO"
    if "SPDLOG_LEVEL" in os.environ:
        spdlog_level = os.environ["SPDLOG_LEVEL"].upper()
        if not spdlog_level.startswith("SPDLOG_LEVEL_"):
            spdlog_level = "SPDLOG_LEVEL_" + spdlog_level
        if spdlog_level not in [
            "SPDLOG_LEVEL_TRACE",
            "SPDLOG_LEVEL_DEBUG",
            "SPDLOG_LEVEL_INFO",
            "SPDLOG_LEVEL_WARN",
            "SPDLOG_LEVEL_ERROR",
            "SPDLOG_LEVEL_CRITICAL",
            "SPDLOG_LEVEL_OFF",
        ]:
            print("SPDLOG_LEVEL can only be trace, debug, info, warn, error, critical, or off")
            exit(255)
    elif env["dev_build"]:
        spdlog_level = "SPDLOG_LEVEL_DEBUG"
    elif env["target"] == "template_release" or env["optimize"] in ["speed", "size"]:
        spdlog_level = "SPDLOG_LEVEL_WARN"

    env.Append(
        CPPDEFINES=[
            ("SPDLOG_ACTIVE_LEVEL", spdlog_level),
            "SPDLOG_FMT_EXTERNAL",
            "SPDLOG_COMPILED_LIB",
            "SPDLOG_NO_EXCEPTIONS",
        ]
    )
    if env["platform"] != "macos":
        env.Append(CPPDEFINES=["SPDLOG_FWRITE_UNLOCKED"])

    env.BuildDependencyLibrary(target="libspdlog", src_dir="spdlog/src", include_dir="spdlog/include")



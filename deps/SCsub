#!/usr/bin/env python

Import("env")


def build_openvic_dataloader(env):
    ovdl_env = SConscript(
        "openvic-dataloader/SConstruct", exports={"build_dir": env["build_dir"] + "/openvic-dataloader"}
    )
    env.AppendUnique(CPPDEFINES=ovdl_env["CPPDEFINES"])
    env.AddLibraryIncludes(ovdl_env.exposed_includes)
    env.Append(LIBPATH=ovdl_env["LIBPATH"])
    env.Prepend(LIBS=ovdl_env["LIBS"])


def build_lexy_vdf(env):
    lvdf_env = SConscript("lexy-vdf/SConstruct", exports={"build_dir": env["build_dir"] + "/lexy-vdf"})
    env.AppendUnique(CPPDEFINES=lvdf_env["CPPDEFINES"])
    env.AddLibraryIncludes(lvdf_env.exposed_includes)
    env.Append(LIBPATH=lvdf_env["LIBPATH"])
    env.Prepend(LIBS=lvdf_env["LIBS"])


